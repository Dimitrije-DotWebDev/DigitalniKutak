<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DigitalniKutak.View.RegisterPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:model="clr-namespace:DigitalniKutak.Model"
             xmlns:viewmodel="clr-namespace:DigitalniKutak.ViewModel"
             x:DataType="viewmodel:RegisterViewModel"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout Margin="250,30,250,50" Spacing="30">
            <Entry Placeholder="Unesite Ime">
            </Entry>
            <Entry Placeholder="Unesite Prezime">
            </Entry>
            <Entry Placeholder="Unesite Sifru" IsPassword="True">
            </Entry>
            <Entry Placeholder="Potvrdite Sifru" IsPassword="True">
            </Entry>
            <Entry Placeholder="Unesite E-Mail">
            </Entry>
            <Picker x:Name="Razred"
            Title="Odaberite Razred">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>I</x:String>
                        <x:String>II</x:String>
                        <x:String>III</x:String>
                        <x:String>IV</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Picker x:Name="Odeljenje"
                Title="Odaberite Odeljenje">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>1</x:String>
                        <x:String>2</x:String>
                        <x:String>3</x:String>
                        <x:String>4</x:String>
                        <x:String>5</x:String>
                        <x:String>6</x:String>
                        <x:String>7</x:String>
                        <x:String>8</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Button Text="Registruj se" Command="{Binding RegistrujKorisnikaCommand}" CommandParameter="{Binding K}"></Button>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>