<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DigitalniKutak.View.KreirajTakmicenje"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:model="clr-namespace:DigitalniKutak.Model"
             xmlns:viewmodel="clr-namespace:DigitalniKutak.ViewModel"
             x:DataType="viewmodel:KreirajTakmicenjaViewModel"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout>
            <Entry Placeholder="Naziv Takmicenja"></Entry>
            <Entry Placeholder="Opis"></Entry>
            <DatePicker></DatePicker>
            <Label Text="Po odeljenju"></Label>
            <CheckBox></CheckBox>
            <Picker
                    Title="Odaberite Kategoriju">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Nauka</x:String>
                        <x:String>Sport</x:String>
                        <x:String>eSport</x:String>
                        <x:String>Ostalo</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <CheckBox></CheckBox>
            <Entry Placeholder="Maksimalni Broj Ucenika Po Ekipi"></Entry>
        </VerticalStackLayout>
    </ScrollView>
        
</ContentPage>